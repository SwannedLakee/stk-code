#. I18N: In Android UI, po_extract_game_data
msgid "Extracting game data..."
msgstr "در حال استخراج اطلاعات بازی..."

#. I18N: In Android UI, po_extract_error
msgid "Game data extraction error"
msgstr "خطا در استخراج اطلاعات بازی"

#. I18N: In Android UI, po_extract_error_msg
msgid "Check remaining device space or reinstall SuperTuxKart."
msgstr "حافظه باقی‌مانده دستگاه را بررسی کنید یا SuperTuxKart را دوباره نصب کنید."

#. I18N: In Android UI, po_quit
#. I18N: ./data/gui/screens/main_menu.stkgui
#. I18N: In the main screen
msgid "Quit"
msgstr "خروج"

#. I18N: ./data/achievements.xml
msgid "Christoffel Columbus"
msgstr "کریستف کلمب"

#. I18N: ./data/achievements.xml
msgid "Play every official track at least once."
msgstr "تمام مسیرهای رسمی را حداقل یک‌بار بازی کنید."

#. I18N: ./data/achievements.xml
msgid "Strike!"
msgstr "ضربات پیاپی!"

#. I18N: ./data/achievements.xml
msgid "Hit 10 karts with a bowling-ball."
msgstr "به ۱۰ ماشین با توپ بولینگ ضربه بزنید."

#. I18N: ./data/achievements.xml
msgid "Arch Enemy"
msgstr "دشمن قسم‌خورده"

#. I18N: ./data/achievements.xml
msgid "Hit the same kart at least 5 times in one race."
msgstr "یک ماشین را در یک مسابقه حداقل ۵ بار هدف قرار دهید."

#. I18N: ./data/achievements.xml
msgid "Marathoner"
msgstr "استقامت"

#. I18N: ./data/achievements.xml
msgid "Finish a race with at least twice the track's default lap number."
msgstr "مسابقه‌ای را با حداقل دو برابر تعداد دور پیش‌فرض مسیر به پایان برسانید."

#. I18N: ./data/achievements.xml
msgid "Skid-row"
msgstr "لغزش‌گاه"

#. I18N: ./data/achievements.xml
msgid "Skid 5 times in a single lap."
msgstr "در یک دور ۵ بار لغزش کنید."

#. I18N: ./data/achievements.xml
msgid "Gold driver"
msgstr "راننده طلایی"

#. I18N: ./data/achievements.xml
msgid ""
"Win against at least 3 AIs in normal race, time-trial, and follow the "
"leader."
msgstr "در مسابقه عادی، آزمون زمان و دنبال‌کردن رهبر، حداقل مقابل ۳ هوش مصنوعی پیروز شوید."

#. I18N: ./data/achievements.xml
msgid "Powerup Love"
msgstr "عاشق قدرت ویژه"

#. I18N: ./data/achievements.xml
msgid "Use 10 or more powerups in a race."
msgstr "در یک مسابقه از ۱۰ قدرت ویژه یا بیشتر استفاده کنید."

#. I18N: ./data/achievements.xml
msgid "Unstoppable"
msgstr "شکست ناپذیر"

#. I18N: ./data/achievements.xml
msgid ""
"Win 5 single races in a row against at least 3 AIs. Beware, restarting a "
"race counts as a loss."
msgstr "۵ مسابقه تک‌نفره پیاپی مقابل حداقل ۳ هوش مصنوعی ببرید. توجه: شروع دوباره مسابقه به‌عنوان باخت شمرده می‌شود."

#. I18N: ./data/achievements.xml
msgid "Banana Lover"
msgstr "عاشق موز"

#. I18N: ./data/achievements.xml
msgid "Collect at least 5 bananas in one race."
msgstr "در یک مسابقه حداقل ۵ موز جمع کنید."

#. I18N: ./data/achievements.xml
msgid "It's secret"
msgstr "این یه رازه"

#. I18N: ./data/achievements.xml
msgid "Really ... a secret."
msgstr "جدی… یه راز."

#. I18N: ./data/achievements.xml
msgid "Mosquito Hunter"
msgstr "شکارچی پشه"

#. I18N: ./data/achievements.xml
msgid ""
"Take your opponents for mosquitos! With the swatter, squash them at least 5 "
"times in a race."
msgstr "حریفان را پشه فرض کنید! با مگس‌کُش حداقل ۵ بار در یک مسابقه آن‌ها را له کنید."

#. I18N: ./data/achievements.xml
msgid "Beyond Luck"
msgstr "فراتر از شانس"

#. I18N: ./data/achievements.xml
msgid ""
"Win 10 single races in a row in Expert or SuperTux against at least 5 AIs. "
"Beware, restarting a race counts as a loss."
msgstr "۱۰ مسابقه تک‌نفره پیاپی در سطح حرفه‌ای یا سوپرتاکس مقابل حداقل ۵ هوش مصنوعی ببرید. توجه: شروع دوباره به‌عنوان باخت شمرده می‌شود."

#. I18N: ./data/grandprix/1_penguinplayground.grandprix
msgid "Penguin Playground"
msgstr "زمین بازی پنگوئن"

#. I18N: ./data/grandprix/2_offthebeatentrack.grandprix
msgid "Off the Beaten Track"
msgstr "خارج از مسیرهای شناخته‌شده"

#. I18N: ./data/grandprix/3_tothemoonandback.grandprix
msgid "To the Moon and Back"
msgstr "تا ماه و بازگشت"

#. I18N: ./data/grandprix/4_atworldsend.grandprix
msgid "At World's End"
msgstr "در انتهای جهان"

