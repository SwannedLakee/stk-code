#: src/network/protocols/chat_commands.cpp:78
msgid ""
"To see the usage format of a command, use /help [command], for example "
"'/help mute' gives information about the /mute command."
msgstr "برای دیدن نحوه استفاده از دستور، از /help [دستور] استفاده کنید؛ مثلاً «/help mute» درباره دستور /mute توضیح می‌دهد."

#: src/network/protocols/chat_commands.cpp:82
msgid ""
"This server supports the following commands: /help /spectate "
"/listserveraddon /playerhasaddon /serverhasaddon /playeraddonscore /kick "
"/mute /unmute /listmute"
msgstr "این سرور دستورهای زیر را پشتیبانی می‌کند: /help /spectate /listserveraddon /playerhasaddon /serverhasaddon /playeraddonscore /kick /mute /unmute /listmute"

#: src/network/protocols/chat_commands.cpp:86
msgid "This command allows to enable or disable spectator mode."
msgstr "این دستور حالت تماشاگر را فعال یا غیرفعال می‌کند."

#: src/network/protocols/chat_commands.cpp:88
msgid "Usage: /spectate [0 or 1], before the game starts"
msgstr "استفاده: /spectate [0 یا 1]، پیش از آغاز بازی"

#: src/network/protocols/chat_commands.cpp:90
msgid ""
"This command allows to find all addons available on this server that contain"
" the searched string in their name."
msgstr "این دستور همه افزونه‌های موجود در سرور که متن جستجو شده را در نام‌شان دارند نشان می‌دهد."

#: src/network/protocols/chat_commands.cpp:93
msgid ""
"Usage: /listserveraddon [option] [addon string to find (at least 3 "
"characters)]. Available options: -track, -arena, -kart, -soccer."
msgstr "استفاده: /listserveraddon [گزینه] [رشته افزونه (حداقل ۳ حرف)]. گزینه‌ها: -track, -arena, -kart, -soccer."

#: src/network/protocols/chat_commands.cpp:97
msgid "This command allows to check if a player has a specific addon."
