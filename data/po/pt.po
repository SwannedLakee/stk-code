#. I18N: ./data/achievements.xml
msgid "Christoffel Columbus"
msgstr "Cristóvão Colombo"

#. I18N: ./data/achievements.xml
msgid "Play every official track at least once."
msgstr "Joga cada pista oficial pelo menos uma vez."

#. I18N: ./data/achievements.xml
msgid "Strike!"
msgstr "Strike!"

#. I18N: ./data/achievements.xml
msgid "Hit 10 karts with a bowling-ball."
msgstr "Atinge 10 karts com uma bola de bólingue."

#. I18N: ./data/achievements.xml
msgid "Arch Enemy"
msgstr "Arquirrival"

#. I18N: ./data/achievements.xml
msgid "Hit the same kart at least 5 times in one race."
msgstr "Atinge o mesmo kart pelo menos 5 vezes numa corrida."

#. I18N: ./data/achievements.xml
msgid "Marathoner"
msgstr "Maratonista"

#. I18N: ./data/achievements.xml
msgid "Finish a race with at least twice the track's default lap number."
msgstr "Termina uma corrida com pelo menos o dobro do número padrão de voltas de uma pista."

#. I18N: ./data/achievements.xml
msgid "Skid-row"
msgstr "Derrapagens em Série"

#. I18N: ./data/achievements.xml
msgid "Skid 5 times in a single lap."
msgstr "Derrapa 5 vezes numa única volta."

#. I18N: ./data/achievements.xml
msgid "Gold driver"
msgstr "Piloto de Ouro"

#. I18N: ./data/achievements.xml
msgid ""
"Win against at least 3 AIs in normal race, time-trial, and follow the "
"leader."
msgstr "Vence contra pelo menos 3 IAs em Corrida Normal, Contrarrelógio e Seguir o Líder."

#. I18N: ./data/achievements.xml
msgid "Powerup Love"
msgstr "Amor Potenciado"

#. I18N: ./data/achievements.xml
msgid "Use 10 or more powerups in a race."
msgstr "Usa 10 ou mais potenciadores numa corrida."

#. I18N: ./data/achievements.xml
msgid "Unstoppable"
msgstr "Imparável"

#. I18N: ./data/achievements.xml
msgid ""
"Win 5 single races in a row against at least 3 AIs. Beware, restarting a "
"race counts as a loss."
msgstr "Vence 5 corridas consecutivas a solo contra pelo menos 3 IAs. Atenção! Reiniciar uma corrida contará como derrota."

#. I18N: ./data/achievements.xml
msgid "Banana Lover"
msgstr "Amante de Bananas"

#. I18N: ./data/achievements.xml
msgid "Collect at least 5 bananas in one race."
msgstr "Apanha pelo menos 5 bananas numa corrida."

#. I18N: ./data/achievements.xml
msgid "It's secret"
msgstr "É segredo"

#. I18N: ./data/achievements.xml
msgid "Really ... a secret."
msgstr "A sério... é segredo."

#. I18N: ./data/achievements.xml
msgid "Mosquito Hunter"
msgstr "Caça-Mosquitos"

#. I18N: ./data/achievements.xml
msgid ""
"Take your opponents for mosquitos! With the swatter, squash them at least 5 "
"times in a race."
msgstr "Trata os teus oponentes como mosquitos! Com o mata-moscas, esmaga-os pelo menos 5 vezes numa corrida."

#. I18N: ./data/achievements.xml
msgid "Beyond Luck"
msgstr "Além da Sorte"

#. I18N: ./data/achievements.xml
msgid ""
"Win 10 single races in a row in Expert or SuperTux against at least 5 AIs. "
"Beware, restarting a race counts as a loss."
msgstr "Vence 10 corridas consecutivas a solo em dificuldade Perito ou SuperTux contra pelo menos 5 IAs. Atenção! Reiniciar uma corrida contará como derrota."

#. I18N: ./data/grandprix/1_penguinplayground.grandprix
